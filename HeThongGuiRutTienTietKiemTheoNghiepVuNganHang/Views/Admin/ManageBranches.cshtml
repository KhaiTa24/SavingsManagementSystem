@model IEnumerable<HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.ChiNhanh>
@{
    ViewData["Title"] = "Quản lý chi nhánh";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="dashboard-container">
    <!-- Sidebar -->
    <div class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Quản trị</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Admin")"><i class="fas fa-tachometer-alt me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("UserManagement","Admin")"><i class="fas fa-users-cog me-2"></i>Quản lý người dùng</a></li>
            <li class="category-item"><a href="@Url.Action("LoginHistory","Admin")"><i class="fas fa-history me-2"></i>Lịch sử đăng nhập</a></li>
            <li class="category-item"><a href="@Url.Action("ActiveSessions","Admin")"><i class="fas fa-user-clock me-2"></i>Session đang hoạt động</a></li>
            <li class="category-item"><a href="@Url.Action("SuspiciousLogins","Admin")"><i class="fas fa-exclamation-triangle me-2"></i>Đăng nhập bất thường</a></li>
            <li class="category-item"><a href="@Url.Action("RoleManagement","Admin")"><i class="fas fa-user-tag me-2"></i>Quản lý vai trò</a></li>
            <li class="category-item"><a href="@Url.Action("SystemNotifications","Admin")"><i class="fas fa-bullhorn me-2"></i>Thông báo hệ thống</a></li>
            <li class="category-item"><a href="@Url.Action("ManageBranches","Admin")" class="active"><i class="fas fa-building me-2"></i>Quản lý chi nhánh</a></li>
            <li class="category-item"><a href="@Url.Action("ManageServices","Admin")"><i class="fas fa-concierge-bell me-2"></i>Quản lý loại dịch vụ</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="content">
        <h2 class="section-title"><i class="fas fa-building me-2"></i>Quản lý chi nhánh</h2>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5>Danh sách chi nhánh</h5>
            <a asp-action="CreateBranch" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i>Thêm chi nhánh
            </a>
        </div>

        <div class="card">
            <div class="card-body">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Mã chi nhánh</th>
                                    <th>Tên chi nhánh</th>
                                    <th>Địa chỉ</th>
                                    <th>Số điện thoại</th>
                                    <th>Giờ làm việc</th>
                                    <th>Trạng thái</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var branch in Model)
                                {
                                    <tr>
                                        <td>@branch.MaCN</td>
                                        <td>@branch.TenChiNhanh</td>
                                        <td>@branch.DiaChi</td>
                                        <td>@branch.SoDienThoai</td>
                                        <td>@branch.GioLamViec</td>
                                        <td>
                                            @if (branch.TrangThaiHD == "HoatDong")
                                            {
                                                <span class="badge bg-success">Hoạt động</span>
                                            }
                                            else if (branch.TrangThaiHD == "TamNgung")
                                            {
                                                <span class="badge bg-warning">Tạm ngưng</span>
                                            }
                                            else if (branch.TrangThaiHD == "DongCua")
                                            {
                                                <span class="badge bg-danger">Đóng cửa</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="EditBranch" asp-route-id="@branch.MaCN" class="btn btn-sm btn-primary">Sửa</a>
                                            <form asp-action="DeleteBranch" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@branch.MaCN" />
                                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa chi nhánh này?')">Xóa</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-building fa-3x text-muted mb-3"></i>
                        <h5>Không có chi nhánh nào</h5>
                        <p class="text-muted">Hiện tại chưa có chi nhánh nào trong hệ thống.</p>
                        <a asp-action="CreateBranch" class="btn btn-primary">Thêm chi nhánh đầu tiên</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>