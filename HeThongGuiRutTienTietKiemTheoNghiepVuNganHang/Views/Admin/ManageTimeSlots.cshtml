@{
    ViewData["Title"] = "Quản lý khung giờ";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="dashboard-container">
    <!-- Sidebar -->
    <div class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Quản trị</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Admin")"><i class="fas fa-tachometer-alt me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("UserManagement","Admin")"><i class="fas fa-users-cog me-2"></i>Quản lý người dùng</a></li>
            <li class="category-item"><a href="@Url.Action("LoginHistory","Admin")"><i class="fas fa-history me-2"></i>Lịch sử đăng nhập</a></li>
            <li class="category-item"><a href="@Url.Action("ActiveSessions","Admin")"><i class="fas fa-user-clock me-2"></i>Session đang hoạt động</a></li>
            <li class="category-item"><a href="@Url.Action("SuspiciousLogins","Admin")"><i class="fas fa-exclamation-triangle me-2"></i>Đăng nhập bất thường</a></li>
            <li class="category-item"><a href="@Url.Action("RoleManagement","Admin")"><i class="fas fa-user-tag me-2"></i>Quản lý vai trò</a></li>
            <li class="category-item"><a href="@Url.Action("SystemNotifications","Admin")"><i class="fas fa-bullhorn me-2"></i>Thông báo hệ thống</a></li>
            <li class="category-item"><a href="@Url.Action("ManageBranches","Admin")"><i class="fas fa-building me-2"></i>Quản lý chi nhánh</a></li>
            <li class="category-item"><a href="@Url.Action("ManageServices","Admin")"><i class="fas fa-concierge-bell me-2"></i>Quản lý loại dịch vụ</a></li>
            <li class="category-item"><a href="@Url.Action("ManageTimeSlots","Admin")" class="active"><i class="fas fa-clock me-2"></i>Quản lý khung giờ</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="section-title"><i class="fas fa-clock me-2"></i>Quản lý khung giờ</h2>
            <a href="@Url.Action("CreateBranch", "Admin")" class="btn btn-primary">
                <i class="fas fa-plus-circle me-2"></i>Thêm chi nhánh
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-list me-2"></i>Danh sách chi nhánh và khung giờ làm việc</h5>
            </div>
            <div class="card-body">
                @{
                    var branches = Model as List<HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.ChiNhanh>;
                }

                @if (branches != null && branches.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Mã chi nhánh</th>
                                    <th>Tên chi nhánh</th>
                                    <th>Địa chỉ</th>
                                    <th>Giờ làm việc</th>
                                    <th>Trạng thái</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var branch in branches)
                                {
                                    <tr>
                                        <td>@branch.MaCN</td>
                                        <td>@branch.TenChiNhanh</td>
                                        <td>@branch.DiaChi</td>
                                        <td>@branch.GioLamViec</td>
                                        <td>
                                            @if (branch.TrangThaiHD == "HoatDong")
                                            {
                                                <span class="badge bg-success">Đang hoạt động</span>
                                            }
                                            else if (branch.TrangThaiHD == "TamNgung")
                                            {
                                                <span class="badge bg-warning">Tạm ngưng</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Đóng cửa</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("EditBranch", "Admin", new { id = branch.MaCN })" class="btn btn-sm btn-primary me-1">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form asp-action="DeleteBranch" method="post" style="display: inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa chi nhánh này?');">
                                                <input type="hidden" name="id" value="@branch.MaCN" />
                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>Chưa có chi nhánh nào. 
                        <a href="@Url.Action("CreateBranch", "Admin")" class="alert-link">Thêm chi nhánh mới</a>.
                    </div>
                }
            </div>
        </div>
    </div>
</div>