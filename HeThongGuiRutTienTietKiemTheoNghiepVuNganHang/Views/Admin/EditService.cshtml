@model HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.LoaiDichVu
@{
    ViewData["Title"] = "Sửa loại dịch vụ";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="dashboard-container">
    <!-- Sidebar -->
    <div class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Quản trị</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Admin")"><i class="fas fa-tachometer-alt me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("UserManagement","Admin")"><i class="fas fa-users-cog me-2"></i>Quản lý người dùng</a></li>
            <li class="category-item"><a href="@Url.Action("LoginHistory","Admin")"><i class="fas fa-history me-2"></i>Lịch sử đăng nhập</a></li>
            <li class="category-item"><a href="@Url.Action("ActiveSessions","Admin")"><i class="fas fa-user-clock me-2"></i>Session đang hoạt động</a></li>
            <li class="category-item"><a href="@Url.Action("SuspiciousLogins","Admin")"><i class="fas fa-exclamation-triangle me-2"></i>Đăng nhập bất thường</a></li>
            <li class="category-item"><a href="@Url.Action("RoleManagement","Admin")"><i class="fas fa-user-tag me-2"></i>Quản lý vai trò</a></li>
            <li class="category-item"><a href="@Url.Action("SystemNotifications","Admin")"><i class="fas fa-bullhorn me-2"></i>Thông báo hệ thống</a></li>
            <li class="category-item"><a href="@Url.Action("ManageBranches","Admin")"><i class="fas fa-building me-2"></i>Quản lý chi nhánh</a></li>
            <li class="category-item"><a href="@Url.Action("ManageServices","Admin")" class="active"><i class="fas fa-concierge-bell me-2"></i>Quản lý loại dịch vụ</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="content">
        <h2 class="section-title"><i class="fas fa-edit me-2"></i>Sửa loại dịch vụ</h2>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Thông tin loại dịch vụ</h5>
            </div>
            <div class="card-body">
                <form asp-action="EditService" method="post">
                    <input type="hidden" asp-for="MaDV" />
                    
                    <div class="mb-3">
                        <label class="form-label">Mã dịch vụ</label>
                        <input asp-for="MaDV" class="form-control" disabled />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tên dịch vụ</label>
                        <input asp-for="TenDV" class="form-control" required />
                        <span asp-validation-for="TenDV" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Thời gian ước tính (phút)</label>
                        <input asp-for="ThoiGianUocTinh" type="number" class="form-control" min="1" required />
                        <span asp-validation-for="ThoiGianUocTinh" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="MoTa" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="ChoPhepDatLich" class="form-check-input" type="checkbox" />
                        <label asp-for="ChoPhepDatLich" class="form-check-label">Cho phép đặt lịch</label>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="ManageServices" class="btn btn-secondary me-md-2">Quay lại</a>
                        <button type="submit" class="btn btn-primary">Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>