@{
    ViewData["Title"] = "Quản trị hệ thống";
    Layout = "_LayoutAdmin";
}

<div class="dashboard-container">
    <aside class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Quản trị</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Admin")" class="active"><i class="fas fa-tachometer-alt me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("UserManagement","Admin")"><i class="fas fa-users-cog me-2"></i>Quản lý người dùng</a></li>
            <li class="category-item"><a href="@Url.Action("LoginHistory","Admin")"><i class="fas fa-history me-2"></i>Lịch sử đăng nhập</a></li>
            <li class="category-item"><a href="@Url.Action("ActiveSessions","Admin")"><i class="fas fa-user-clock me-2"></i>Session đang hoạt động</a></li>
            <li class="category-item"><a href="@Url.Action("SuspiciousLogins","Admin")"><i class="fas fa-exclamation-triangle me-2"></i>Đăng nhập bất thường</a></li>
            <li class="category-item"><a href="@Url.Action("RoleManagement","Admin")"><i class="fas fa-user-tag me-2"></i>Quản lý vai trò</a></li>
            <li class="category-item"><a href="@Url.Action("SystemNotifications","Admin")"><i class="fas fa-bullhorn me-2"></i>Thông báo hệ thống</a></li>
            <li class="category-item"><a href="@Url.Action("ManageBranches","Admin")"><i class="fas fa-building me-2"></i>Quản lý chi nhánh</a></li>
            <li class="category-item"><a href="@Url.Action("ManageServices","Admin")"><i class="fas fa-concierge-bell me-2"></i>Quản lý loại dịch vụ</a></li>
        </ul>
    </aside>

    <section class="content">
        @if (ViewBag.LoginSuccess != null)
        {
            <div class="alert alert-success mb-3" role="alert">
                <i class="fas fa-check-circle me-2"></i> @ViewBag.LoginSuccess
            </div>
        }
        
        <div class="mb-4">
            <h2 class="section-title mb-2"><i class="fas fa-tachometer-alt me-2"></i>Tổng quan hệ thống</h2>
            <p class="text-muted">Xin chào, <strong>@(ViewBag.User?.HoTen ?? User.Identity?.Name ?? "Administrator")</strong>! Toàn quyền quản trị hệ thống BankSave.</p>
        </div>
        
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card stat-card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="icon me-3"><i class="fas fa-users"></i></div>
                            <div>
                                <div class="stat-number">@ViewBag.TotalUsers</div>
                                <div class="stat-label">Tổng người dùng</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="icon me-3"><i class="fas fa-exchange-alt"></i></div>
                            <div>
                                <div class="stat-number">@ViewBag.TotalTransactions</div>
                                <div class="stat-label">Tổng giao dịch</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="icon me-3"><i class="fas fa-book"></i></div>
                            <div>
                                <div class="stat-number">@ViewBag.TotalSavingsBooks</div>
                                <div class="stat-label">Sổ tiết kiệm</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="icon me-3"><i class="fas fa-credit-card"></i></div>
                            <div>
                                <div class="stat-number">@ViewBag.TotalBankAccounts</div>
                                <div class="stat-label">Tài khoản ngân hàng</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <i class="fas fa-shield-alt me-2"></i>Chức năng quản trị
                    </div>
                    <div class="card-body">
                        <ul>
                            <li><i class="fas fa-check text-success me-2"></i>Quản lý tài khoản người dùng (tạo/sửa/xóa/khóa)</li>
                            <li><i class="fas fa-check text-success me-2"></i>Cấp và thu hồi quyền truy cập</li>
                            <li><i class="fas fa-check text-success me-2"></i>Đặt lại mật khẩu người dùng</li>
                            <li><i class="fas fa-check text-success me-2"></i>Gửi thông báo toàn hệ thống</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <i class="fas fa-exclamation-triangle me-2"></i>Lưu ý quan trọng
                    </div>
                    <div class="card-body">
                        <div class="alert alert-warning">
                            <strong><i class="fas fa-exclamation-circle me-2"></i>Cảnh báo bảo mật:</strong>
                            <ul class="mt-2 mb-0">
                                <li>Không chia sẻ quyền Admin cho người không có trách nhiệm</li>
                                <li>Kiểm tra kỹ trước khi xóa hoặc khóa tài khoản</li>
                                <li>Backup dữ liệu định kỳ</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
