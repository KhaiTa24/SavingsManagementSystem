@{
    ViewData["Title"] = "Lịch sử đăng nhập";
    Layout = "_LayoutAdmin";
}

<div class="dashboard-container">
    <aside class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Quản trị</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Admin")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Overview" ? "active" : "")"><i class="fas fa-tachometer-alt me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("UserManagement","Admin")"><i class="fas fa-users-cog me-2"></i>Quản lý người dùng</a></li>
            <li class="category-item"><a href="@Url.Action("LoginHistory","Admin")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "LoginHistory" ? "active" : "")"><i class="fas fa-history me-2"></i>Lịch sử đăng nhập</a></li>
            <li class="category-item"><a href="@Url.Action("ActiveSessions","Admin")"><i class="fas fa-user-clock me-2"></i>Session đang hoạt động</a></li>
            <li class="category-item"><a href="@Url.Action("SuspiciousLogins","Admin")"><i class="fas fa-exclamation-triangle me-2"></i>Đăng nhập bất thường</a></li>
            <li class="category-item"><a href="@Url.Action("RoleManagement","Admin")"><i class="fas fa-user-tag me-2"></i>Quản lý vai trò</a></li>
            <li class="category-item"><a href="@Url.Action("SystemNotifications","Admin")"><i class="fas fa-bullhorn me-2"></i>Thông báo hệ thống</a></li>
            <li class="category-item"><a href="@Url.Action("ManageBranches","Admin")"><i class="fas fa-building me-2"></i>Quản lý chi nhánh</a></li>
            <li class="category-item"><a href="@Url.Action("ManageServices","Admin")"><i class="fas fa-concierge-bell me-2"></i>Quản lý loại dịch vụ</a></li>
        </ul>
    </aside>

    <section class="content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="mb-4">
            <h2 class="section-title mb-2"><i class="fas fa-history me-2"></i>Lịch sử đăng nhập</h2>
            <p class="text-muted">Xem lịch sử đăng nhập của tất cả người dùng trong hệ thống.</p>
        </div>

        <!-- Bộ lọc -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="fas fa-filter me-2"></i>Bộ lọc
            </div>
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Địa chỉ IP</label>
                        <input type="text" class="form-control" name="ipFilter" value="@ViewBag.IPFilter" placeholder="Nhập địa chỉ IP">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Từ ngày</label>
                        <input type="date" class="form-control" name="fromDate" value="@ViewBag.FromDate">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Đến ngày</label>
                        <input type="date" class="form-control" name="toDate" value="@ViewBag.ToDate">
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="btn-group" role="group">
                            <button type="submit" class="btn btn-primary"><i class="fas fa-search me-1"></i> Lọc</button>
                            <a href="@Url.Action("LoginHistory", "Admin")" class="btn btn-secondary"><i class="fas fa-redo me-1"></i> Đặt lại</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Bảng lịch sử đăng nhập -->
        <div class="card">
            <div class="card-header">
                <i class="fas fa-table me-2"></i>Danh sách lịch sử đăng nhập
            </div>
            <div class="card-body">
                @if (ViewBag.LoginHistories != null && ((List<HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.LichSuDangNhap>)ViewBag.LoginHistories).Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Mã DN</th>
                                    <th>Loại người dùng</th>
                                    <th>Thời gian đăng nhập</th>
                                    <th>Thời gian đăng xuất</th>
                                    <th>Số lần thất bại</th>
                                    <th>Địa chỉ IP</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in (List<HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.LichSuDangNhap>)ViewBag.LoginHistories)
                                {
                                    <tr>
                                        <td>@item.MaDN</td>
                                        <td>
                                            @if (item.LoaiNguoiDung == "Admin")
                                            {
                                                <span class="badge bg-danger">@item.LoaiNguoiDung</span>
                                            }
                                            else if (item.LoaiNguoiDung == "KhachHang")
                                            {
                                                <span class="badge bg-primary">@item.LoaiNguoiDung</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@item.LoaiNguoiDung</span>
                                            }
                                        </td>
                                        <td>@item.TGDangNhap.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                        <td>
                                            @if (item.TGDangXuat.HasValue)
                                            {
                                                @item.TGDangXuat.Value.ToString("dd/MM/yyyy HH:mm:ss")
                                            }
                                            else
                                            {
                                                <span class="text-muted">Chưa đăng xuất</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.SoLanDangNhapThatBai > 0)
                                            {
                                                <span class="badge bg-warning">@item.SoLanDangNhapThatBai</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">@item.SoLanDangNhapThatBai</span>
                                            }
                                        </td>
                                        <td>@item.DiaChiIP</td>
                                        <td>
                                            @if (item.TrangThai == "DangNhap")
                                            {
                                                <span class="badge bg-success">@item.TrangThai</span>
                                            }
                                            else if (item.TrangThai == "DangXuat")
                                            {
                                                <span class="badge bg-secondary">@item.TrangThai</span>
                                            }
                                            else if (item.TrangThai == "ThatBai")
                                            {
                                                <span class="badge bg-danger">@item.TrangThai</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@item.TrangThai</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-history fa-3x text-muted mb-3"></i>
                        <h4 class="text-muted">Không có dữ liệu lịch sử đăng nhập</h4>
                        <p class="text-muted">Hệ thống chưa ghi nhận hoạt động đăng nhập nào phù hợp với điều kiện tìm kiếm.</p>
                    </div>
                }
            </div>
        </div>
    </section>
</div>