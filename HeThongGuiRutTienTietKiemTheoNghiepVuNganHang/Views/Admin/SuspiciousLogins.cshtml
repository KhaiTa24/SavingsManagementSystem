@{
    ViewData["Title"] = "Đăng nhập bất thường";
    Layout = "_LayoutAdmin";
}

<div class="dashboard-container">
    <aside class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Quản trị</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Admin")" class="active"><i class="fas fa-tachometer-alt me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("UserManagement","Admin")"><i class="fas fa-users-cog me-2"></i>Quản lý người dùng</a></li>
            <li class="category-item"><a href="@Url.Action("LoginHistory","Admin")"><i class="fas fa-history me-2"></i>Lịch sử đăng nhập</a></li>
            <li class="category-item"><a href="@Url.Action("ActiveSessions","Admin")"><i class="fas fa-user-clock me-2"></i>Session đang hoạt động</a></li>
            <li class="category-item"><a href="@Url.Action("SuspiciousLogins","Admin")"><i class="fas fa-exclamation-triangle me-2"></i>Đăng nhập bất thường</a></li>
            <li class="category-item"><a href="@Url.Action("RoleManagement","Admin")"><i class="fas fa-user-tag me-2"></i>Quản lý vai trò</a></li>
            <li class="category-item"><a href="@Url.Action("SystemNotifications","Admin")"><i class="fas fa-bullhorn me-2"></i>Thông báo hệ thống</a></li>
            <li class="category-item"><a href="@Url.Action("ManageBranches","Admin")"><i class="fas fa-building me-2"></i>Quản lý chi nhánh</a></li>
            <li class="category-item"><a href="@Url.Action("ManageServices","Admin")"><i class="fas fa-concierge-bell me-2"></i>Quản lý loại dịch vụ</a></li>
    </aside>

    <section class="content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="mb-4">
            <h2 class="section-title mb-2"><i class="fas fa-exclamation-triangle me-2"></i>Đăng nhập bất thường</h2>
            <p class="text-muted">Phát hiện và cảnh báo các hoạt động đăng nhập đáng ngờ trong hệ thống.</p>
        </div>

        <!-- Bảng đăng nhập bất thường -->
        <div class="card">
            <div class="card-header">
                <i class="fas fa-table me-2"></i>Danh sách đăng nhập bất thường
            </div>
            <div class="card-body">
                @if (ViewBag.SuspiciousLogins != null && ((List<HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.LichSuDangNhap>)ViewBag.SuspiciousLogins).Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Mã DN</th>
                                    <th>Họ tên</th>
                                    <th>Loại người dùng</th>
                                    <th>Thời gian đăng nhập</th>
                                    <th>Số lần thất bại</th>
                                    <th>Địa chỉ IP</th>
                                    <th>Trạng thái</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in (List<HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.LichSuDangNhap>)ViewBag.SuspiciousLogins)
                                {
                                    <tr>
                                        <td>@item.MaDN</td>
                                        <td>@item.NguoiDung?.HoTen</td>
                                        <td>
                                            @if (item.LoaiNguoiDung == "Admin")
                                            {
                                                <span class="badge bg-danger">@item.LoaiNguoiDung</span>
                                            }
                                            else if (item.LoaiNguoiDung == "KhachHang")
                                            {
                                                <span class="badge bg-primary">@item.LoaiNguoiDung</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@item.LoaiNguoiDung</span>
                                            }
                                        </td>
                                        <td>@item.TGDangNhap.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                        <td>
                                            <span class="badge bg-warning">@item.SoLanDangNhapThatBai</span>
                                        </td>
                                        <td>@item.DiaChiIP</td>
                                        <td>
                                            @if (item.TrangThai == "ThatBai")
                                            {
                                                <span class="badge bg-danger">@item.TrangThai</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@item.TrangThai</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <button type="button" class="btn btn-sm btn-info" onclick="viewDetails('@item.MaLichSu')">
                                                    <i class="fas fa-eye me-1"></i> Chi tiết
                                                </button>
                                                <button type="button" class="btn btn-sm btn-warning" onclick="blockIP('@item.DiaChiIP')">
                                                    <i class="fas fa-ban me-1"></i> Chặn IP
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                        <h4 class="text-success">Không có đăng nhập bất thường</h4>
                        <p class="text-muted">Hệ thống không phát hiện hoạt động đăng nhập đáng ngờ nào.</p>
                    </div>
                }
            </div>
        </div>
    </section>
</div>

<script>
    function viewDetails(sessionId) {
        // Đây là nơi bạn sẽ gọi API để xem chi tiết session
        alert('Chức năng xem chi tiết sẽ được triển khai ở đây. Session ID: ' + sessionId);
    }

    function blockIP(ipAddress) {
        if (confirm('Bạn có chắc chắn muốn chặn địa chỉ IP ' + ipAddress + ' không?')) {
            // Đây là nơi bạn sẽ gọi API để chặn IP
            alert('Chức năng chặn IP sẽ được triển khai ở đây. IP: ' + ipAddress);
        }
    }
</script>