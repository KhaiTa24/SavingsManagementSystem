@using HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models
@{
    ViewData["Title"] = "Quản lý khách hàng";
    Layout = "_LayoutManagement";
    var customers = ViewBag.Customers as List<User>;
    var q = ViewBag.Query as string;
}

<div class="dashboard-container">
    <aside class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Chức năng</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Management")"><i class="fas fa-chart-line me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("TransactionApproval","Management")"><i class="fas fa-check-circle me-2"></i>Duyệt giao dịch</a></li>
            <li class="category-item"><a href="@Url.Action("SavingsBookManagement","Management")"><i class="fas fa-book me-2"></i>Quản lý sổ tiết kiệm</a></li>
            <li class="category-item"><a href="@Url.Action("TermDepositProducts","Management")"><i class="fas fa-box me-2"></i>Gói tiết kiệm</a></li>
            <li class="category-item"><a href="@Url.Action("TellerManagement","Management")"><i class="fas fa-users-cog me-2"></i>Quản lý nhân viên</a></li>
            <li class="category-item"><a href="@Url.Action("CustomerManagement","Management")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "CustomerManagement" ? "active" : "")"><i class="fas fa-users me-2"></i>Quản lý khách hàng</a></li>
            <li class="category-item"><a href="@Url.Action("DailyReports","Management")"><i class="fas fa-file-alt me-2"></i>Báo cáo nhân viên</a></li>
            <li class="category-item"><a href="@Url.Action("ManageAppointments","Management")"><i class="fas fa-calendar-alt me-2"></i>Quản lý lịch hẹn</a></li>
        </ul>
    </aside>

    <section class="content">
        <!-- Bộ lọc gọn gàng -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="filterDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-filter me-1"></i>Bộ lọc
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="filterDropdown">
                                <li><a class="dropdown-item filter-option" href="#" data-filter="name">Tên khách hàng</a></li>
                                <li><a class="dropdown-item filter-option" href="#" data-filter="email">Email</a></li>
                                <li><a class="dropdown-item filter-option" href="#" data-filter="phone">Số điện thoại</a></li>
                                <li><a class="dropdown-item filter-option" href="#" data-filter="cccd">CCCD</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item filter-option" href="#" data-filter="sort">Sắp xếp</a></li>
                            </ul>
                        </div>
                        
                        <div id="filterInputContainer" class="d-flex align-items-center gap-2">
                            <!-- Các input lọc sẽ được hiển thị ở đây -->
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button id="applyFilter" class="btn btn-primary">
                            <i class="fas fa-filter me-1"></i>Áp dụng
                        </button>
                        <a href="@Url.Action("CustomerManagement", "Management")" class="btn btn-outline-secondary">
                            <i class="fas fa-times"></i>
                        </a>
                    </div>
                </div>
                
                <!-- Form ẩn để submit -->
                <form id="filterForm" method="get" asp-controller="Management" asp-action="CustomerManagement" class="d-none">
                    <input type="hidden" name="q" id="filterName" value="@q" />
                    <input type="hidden" name="email" id="filterEmail" value="@ViewBag.Email" />
                    <input type="hidden" name="phone" id="filterPhone" value="@ViewBag.Phone" />
                    <input type="hidden" name="cccd" id="filterCCCD" value="@ViewBag.CCCD" />
                    <input type="hidden" name="sortBy" id="filterSortBy" value="@ViewBag.SortBy" />
                    <input type="hidden" name="sortOrder" id="filterSortOrder" value="@ViewBag.SortOrder" />
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="fas fa-users me-2"></i>Danh sách khách hàng
            </div>
            <div class="card-body p-0">
                @if (customers != null && customers.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Họ tên</th>
                                    <th>Email</th>
                                    <th>SĐT</th>
                                    <th>CCCD</th>
                                    <th style="width:160px">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kh in customers)
                                {
                                    <tr>
                                        <td><i class="fas fa-user me-1"></i>@kh.HoTen</td>
                                        <td>@kh.Email</td>
                                        <td>@kh.SDT</td>
                                        <td>@kh.CCCD</td>
                                        <td>
                                            <a class="btn btn-info btn-sm" asp-controller="Management" asp-action="CustomerDetails" asp-route-id="@kh.Id"><i class="fas fa-eye me-1"></i> Xem</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted p-4">
                        <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                        Không có dữ liệu khách hàng phù hợp.
                    </div>
                }
            </div>
        </div>
    </section>
</div>

@section Scripts {
<script>
    $(document).ready(function() {
        let currentFilter = '';
        
        // Xử lý khi chọn tùy chọn lọc
        $('.filter-option').on('click', function(e) {
            e.preventDefault();
            const filterType = $(this).data('filter');
            currentFilter = filterType;
            
            // Xóa input hiện tại
            $('#filterInputContainer').empty();
            
            // Thêm input tương ứng
            switch(filterType) {
                case 'name':
                    $('#filterInputContainer').append(`
                        <input type="text" id="nameInput" class="form-control" placeholder="Nhập tên khách hàng" value="${$('#filterName').val()}">
                    `);
                    break;
                case 'email':
                    $('#filterInputContainer').append(`
                        <input type="email" id="emailInput" class="form-control" placeholder="Nhập email" value="${$('#filterEmail').val()}">
                    `);
                    break;
                case 'phone':
                    $('#filterInputContainer').append(`
                        <input type="text" id="phoneInput" class="form-control" placeholder="Nhập số điện thoại" value="${$('#filterPhone').val()}">
                    `);
                    break;
                case 'cccd':
                    $('#filterInputContainer').append(`
                        <input type="text" id="cccdInput" class="form-control" placeholder="Nhập CCCD" value="${$('#filterCCCD').val()}">
                    `);
                    break;
                case 'sort':
                    $('#filterInputContainer').append(`
                        <select id="sortByInput" class="form-select">
                            <option value="name" ${$('#filterSortBy').val() === 'name' ? 'selected' : ''}>Sắp xếp theo tên</option>
                            <option value="email" ${$('#filterSortBy').val() === 'email' ? 'selected' : ''}>Sắp xếp theo email</option>
                            <option value="phone" ${$('#filterSortBy').val() === 'phone' ? 'selected' : ''}>Sắp xếp theo SĐT</option>
                            <option value="cccd" ${$('#filterSortBy').val() === 'cccd' ? 'selected' : ''}>Sắp xếp theo CCCD</option>
                        </select>
                        <select id="sortOrderInput" class="form-select">
                            <option value="asc" ${$('#filterSortOrder').val() === 'asc' ? 'selected' : ''}>Tăng dần</option>
                            <option value="desc" ${$('#filterSortOrder').val() === 'desc' ? 'selected' : ''}>Giảm dần</option>
                        </select>
                    `);
                    break;
            }
        });
        
        // Xử lý khi nhấn nút Áp dụng
        $('#applyFilter').on('click', function() {
            // Cập nhật giá trị hidden inputs
            switch(currentFilter) {
                case 'name':
                    $('#filterName').val($('#nameInput').val());
                    break;
                case 'email':
                    $('#filterEmail').val($('#emailInput').val());
                    break;
                case 'phone':
                    $('#filterPhone').val($('#phoneInput').val());
                    break;
                case 'cccd':
                    $('#filterCCCD').val($('#cccdInput').val());
                    break;
                case 'sort':
                    $('#filterSortBy').val($('#sortByInput').val());
                    $('#filterSortOrder').val($('#sortOrderInput').val());
                    break;
            }
            
            // Submit form
            $('#filterForm').submit();
        });
    });
</script>
}
