@model IEnumerable<HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.BaoCaoGiaoDichNgay>
@{
    ViewData["Title"] = "Báo cáo giao dịch ngày";
    Layout = "_LayoutManagement";
}

<div class="dashboard-container">
    <aside class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Chức năng</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Management")"><i class="fas fa-chart-line me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("TransactionApproval","Management")"><i class="fas fa-check-circle me-2"></i>Duyệt giao dịch</a></li>
            <li class="category-item"><a href="@Url.Action("SavingsBookManagement","Management")"><i class="fas fa-book me-2"></i>Quản lý sổ tiết kiệm</a></li>
            <li class="category-item"><a href="@Url.Action("TermDepositProducts","Management")"><i class="fas fa-box me-2"></i>Gói tiết kiệm</a></li>
            <li class="category-item"><a href="@Url.Action("TellerManagement","Management")"><i class="fas fa-users-cog me-2"></i>Quản lý nhân viên</a></li>
            <li class="category-item"><a href="@Url.Action("CustomerManagement","Management")"><i class="fas fa-users me-2"></i>Quản lý khách hàng</a></li>
            <li class="category-item"><a href="@Url.Action("DailyReports","Management")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "DailyReports" ? "active" : "")"><i class="fas fa-file-alt me-2"></i>Báo cáo nhân viên</a></li>
            <li class="category-item"><a href="@Url.Action("ManageAppointments","Management")"><i class="fas fa-calendar-alt me-2"></i>Quản lý lịch hẹn</a></li>
        </ul>
    </aside>

    <section class="content">
        @if (TempData["ActionMessage"] != null)
        {
            <div class="alert alert-success mb-3" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["ActionMessage"]
            </div>
        }

        <div class="mb-4">
            <h2 class="section-title mb-2"><i class="fas fa-file-alt me-2"></i>@ViewData["Title"]</h2>
            <p class="text-muted">Danh sách báo cáo giao dịch ngày được gửi bởi nhân viên giao dịch.</p>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-list me-2"></i>Danh sách báo cáo</h5>
            </div>
            <div class="card-body">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Mã báo cáo</th>
                                    <th>Ngày báo cáo</th>
                                    <th>Nhân viên</th>
                                    <th>Loại báo cáo</th>
                                    <th>Ngày tạo</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var report in Model)
                                {
                                    <tr>
                                        <td>#@report.MaBaoCao</td>
                                        <td>@report.NgayBaoCao.ToString("dd/MM/yyyy")</td>
                                        <td>@(report.NhanVien?.HoTenNV ?? report.NhanVien?.HoTen ?? "Không xác định")</td>
                                        <td>
                                            @if (report.LoaiBaoCao == "BaoCaoSoTien")
                                            {
                                                <span class="badge bg-primary">Báo cáo số tiền</span>
                                            }
                                            else if (report.LoaiBaoCao == "BaoCaoSoLuongGD")
                                            {
                                                <span class="badge bg-success">Báo cáo số lượng</span>
                                            }
                                        </td>
                                        <td>@report.NgayLap.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <a href="@Url.Action("DailyReportDetails", "Management", new { id = report.MaBaoCao })" class="btn btn-info btn-sm">
                                                <i class="fas fa-eye me-1"></i> Xem
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-file-alt fa-3x text-muted mb-3"></i>
                        <h5>Chưa có báo cáo nào</h5>
                        <p class="text-muted">Hiện chưa có nhân viên nào gửi báo cáo.</p>
                    </div>
                }
            </div>
        </div>
    </section>
</div>