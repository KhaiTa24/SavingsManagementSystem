@using HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models
@{
    ViewData["Title"] = "Chi tiết khách hàng";
    Layout = "_LayoutManagement";
    var kh = ViewBag.Customer as User;
    var bankAccounts = ViewBag.BankAccounts as List<TaiKhoanNganHang>;
    var savingsTransactions = ViewBag.SavingsTransactions as List<GiaoDichTietKiem>;
    var bankTransactions = ViewBag.BankTransactions as List<GiaoDichNganHang>;
}

<div class="dashboard-container">
    <aside class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Chức năng</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Management")"><i class="fas fa-chart-line me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("TransactionApproval","Management")"><i class="fas fa-check-circle me-2"></i>Duyệt giao dịch</a></li>
            <li class="category-item"><a href="@Url.Action("SavingsBookManagement","Management")"><i class="fas fa-book me-2"></i>Quản lý sổ tiết kiệm</a></li>
            <li class="category-item"><a href="@Url.Action("TermDepositProducts","Management")"><i class="fas fa-box me-2"></i>Gói tiết kiệm</a></li>
            <li class="category-item"><a href="@Url.Action("TellerManagement","Management")"><i class="fas fa-users-cog me-2"></i>Quản lý nhân viên</a></li>
            <li class="category-item"><a href="@Url.Action("CustomerManagement","Management")" class="active"><i class="fas fa-users me-2"></i>Quản lý khách hàng</a></li>
            <li class="category-item"><a href="@Url.Action("DailyReports","Management")"><i class="fas fa-file-alt me-2"></i>Báo cáo nhân viên</a></li>
            <li class="category-item"><a href="@Url.Action("ManageAppointments","Management")"><i class="fas fa-calendar-alt me-2"></i>Quản lý lịch hẹn</a></li>
        </ul>
    </aside>

    <section class="content">
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header"><i class="fas fa-user me-2"></i>Thông tin khách hàng</div>
                    <div class="card-body">
                        @if (kh != null)
                        {
                            <p class="mb-1"><strong>Họ tên:</strong> @kh.HoTen</p>
                            <p class="mb-1"><strong>Email:</strong> @kh.Email</p>
                            <p class="mb-1"><strong>SĐT:</strong> @kh.SDT</p>
                            <p class="mb-1"><strong>CCCD:</strong> @kh.CCCD</p>
                        }
                        else
                        {
                            <div class="text-muted">Không tìm thấy khách hàng.</div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header"><i class="fas fa-wallet me-2"></i>Tổng quan tài chính</div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="card stat-card">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center">
                                            <div class="icon me-3"><i class="fas fa-credit-card"></i></div>
                                            <div>
                                                <div class="stat-number">@(bankAccounts?.Count ?? 0)</div>
                                                <div class="stat-label">Số tài khoản NH</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card stat-card">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center">
                                            <div class="icon me-3"><i class="fas fa-piggy-bank"></i></div>
                                            <div>
                                                <div class="stat-number">@string.Format("{0:N0}", (ViewBag.TotalSavings ?? 0)) đ</div>
                                                <div class="stat-label">Tổng tiền gửi tiết kiệm</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header"><i class="fas fa-credit-card me-2"></i>Tài khoản ngân hàng</div>
            <div class="card-body p-0">
                @if (bankAccounts != null && bankAccounts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Số tài khoản</th>
                                    <th>Số dư</th>
                                    <th>Trạng thái</th>
                                    <th>Sổ tiết kiệm</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in bankAccounts)
                                {
                                    <tr>
                                        <td><i class="fas fa-hashtag me-1 text-muted"></i>@b.SoTaiKhoan</td>
                                        <td><strong>@string.Format("{0:N0}", b.SoDu) đ</strong></td>
                                        <td><span class="badge bg-secondary">@b.TrangThai</span></td>
                                        <td>
                                            @if (b.SoTietKiems != null && b.SoTietKiems.Any())
                                            {
                                                <ul class="mb-0">
                                                    @foreach (var s in b.SoTietKiems)
                                                    {
                                                        <li>
                                                            <span class="badge bg-info me-2">#@s.MaSTK</span>
                                                            @string.Format("{0:N0}", s.SoTienGui) đ - @s.LaiSuat% - @s.TrangThai
                                                        </li>
                                                    }
                                                </ul>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Không có sổ tiết kiệm</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted p-4">
                        <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                        Không có tài khoản ngân hàng.
                    </div>
                }
            </div>
        </div>

        <!-- Giao dịch sổ tiết kiệm -->
        <div class="card mb-4">
            <div class="card-header"><i class="fas fa-piggy-bank me-2"></i>Giao dịch sổ tiết kiệm</div>
            <!-- Bộ lọc giao dịch tiết kiệm -->
            <div class="card-body p-3 bg-light border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" id="savingsFilterDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-filter me-1"></i>Bộ lọc
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="savingsFilterDropdown">
                                <li><a class="dropdown-item savings-filter-option" href="#" data-filter="type">Loại giao dịch</a></li>
                                <li><a class="dropdown-item savings-filter-option" href="#" data-filter="date">Ngày giao dịch</a></li>
                                <li><a class="dropdown-item savings-filter-option" href="#" data-filter="amount">Số tiền</a></li>
                            </ul>
                        </div>
                        
                        <div id="savingsFilterInputContainer" class="d-flex align-items-center gap-2">
                            <!-- Các input lọc giao dịch tiết kiệm sẽ được hiển thị ở đây -->
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button id="applySavingsFilter" class="btn btn-primary btn-sm">
                            <i class="fas fa-filter me-1"></i>Lọc
                        </button>
                        <button id="clearSavingsFilter" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                @if (savingsTransactions != null && savingsTransactions.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Mã GD</th>
                                    <th>STK</th>
                                    <th>Loại</th>
                                    <th>Ngày GD</th>
                                    <th>Số tiền</th>
                                    <th>Nhân viên GD</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var gd in savingsTransactions)
                                {
                                    <tr>
                                        <td><i class="fas fa-hashtag me-1 text-muted"></i>@gd.MaGD</td>
                                        <td>@(gd.SoTietKiem?.MaSTK ?? 0)</td>
                                        <td><span class="badge bg-@(gd.LoaiGD == "Gửi" ? "success" : "warning")">@gd.LoaiGD</span></td>
                                        <td>@gd.NgayGD.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td><strong>@string.Format("{0:N0}", gd.SoTien) đ</strong></td>
                                        <td>@(gd.NhanVien?.HoTen ?? "N/A")</td>
                                        <td><span class="badge bg-secondary">@gd.TrangThaiGD</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted p-4">
                        <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                        Không có giao dịch tiết kiệm.
                    </div>
                }
            </div>
        </div>

        <!-- Giao dịch tài khoản ngân hàng -->
        <div class="card">
            <div class="card-header"><i class="fas fa-money-check-alt me-2"></i>Giao dịch tài khoản ngân hàng</div>
            <!-- Bộ lọc giao dịch ngân hàng -->
            <div class="card-body p-3 bg-light border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" id="bankFilterDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-filter me-1"></i>Bộ lọc
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="bankFilterDropdown">
                                <li><a class="dropdown-item bank-filter-option" href="#" data-filter="type">Loại giao dịch</a></li>
                                <li><a class="dropdown-item bank-filter-option" href="#" data-filter="date">Ngày giao dịch</a></li>
                                <li><a class="dropdown-item bank-filter-option" href="#" data-filter="amount">Số tiền</a></li>
                            </ul>
                        </div>
                        
                        <div id="bankFilterInputContainer" class="d-flex align-items-center gap-2">
                            <!-- Các input lọc giao dịch ngân hàng sẽ được hiển thị ở đây -->
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button id="applyBankFilter" class="btn btn-primary btn-sm">
                            <i class="fas fa-filter me-1"></i>Lọc
                        </button>
                        <button id="clearBankFilter" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                @if (bankTransactions != null && bankTransactions.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Mã GD</th>
                                    <th>Số tài khoản</th>
                                    <th>Loại</th>
                                    <th>Ngày GD</th>
                                    <th>Số tiền</th>
                                    <th>Nhân viên GD</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var gd in bankTransactions)
                                {
                                    <tr>
                                        <td><i class="fas fa-hashtag me-1 text-muted"></i>@gd.MaGD</td>
                                        <td>@gd.SoTaiKhoan</td>
                                        <td><span class="badge bg-@(gd.LoaiGD == "Nạp tiền" ? "success" : "warning")">@gd.LoaiGD</span></td>
                                        <td>@gd.NgayGD.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td><strong>@string.Format("{0:N0}", gd.SoTien) đ</strong></td>
                                        <td>@(gd.NhanVien?.HoTen ?? "N/A")</td>
                                        <td><span class="badge bg-secondary">@gd.TrangThaiGD</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted p-4">
                        <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                        Không có giao dịch ngân hàng.
                    </div>
                }
            </div>
        </div>
    </section>
</div>

@section Scripts {
<script>
    $(document).ready(function() {
        // Bộ lọc giao dịch tiết kiệm
        let currentSavingsFilter = '';
        
        $('.savings-filter-option').on('click', function(e) {
            e.preventDefault();
            const filterType = $(this).data('filter');
            currentSavingsFilter = filterType;
            
            $('#savingsFilterInputContainer').empty();
            
            switch(filterType) {
                case 'type':
                    $('#savingsFilterInputContainer').append(`
                        <select id="savingsTypeInput" class="form-select form-select-sm">
                            <option value="">Tất cả loại</option>
                            <option value="Gửi" @(ViewBag.SavingsType == "Gửi" ? "selected" : "")>Gửi</option>
                            <option value="Rút" @(ViewBag.SavingsType == "Rút" ? "selected" : "")>Rút</option>
                        </select>
                    `);
                    break;
                case 'date':
                    $('#savingsFilterInputContainer').append(`
                        <input type="date" id="savingsFromDateInput" class="form-control form-control-sm" placeholder="Từ ngày" value="@ViewBag.SavingsFromDate">
                        <input type="date" id="savingsToDateInput" class="form-control form-control-sm" placeholder="Đến ngày" value="@ViewBag.SavingsToDate">
                    `);
                    break;
                case 'amount':
                    $('#savingsFilterInputContainer').append(`
                        <input type="number" id="savingsMinAmountInput" class="form-control form-control-sm" placeholder="Số tiền tối thiểu" value="@ViewBag.SavingsMinAmount">
                        <input type="number" id="savingsMaxAmountInput" class="form-control form-control-sm" placeholder="Số tiền tối đa" value="@ViewBag.SavingsMaxAmount">
                    `);
                    break;
            }
        });
        
        $('#applySavingsFilter').on('click', function() {
            // Tạo URL với các tham số lọc
            let url = window.location.pathname + '?id=@(ViewBag.Customer?.Id)';
            
            if (currentSavingsFilter === 'type' && $('#savingsTypeInput').val()) {
                url += '&savingsType=' + encodeURIComponent($('#savingsTypeInput').val());
            }
            
            if (currentSavingsFilter === 'date') {
                if ($('#savingsFromDateInput').val()) {
                    url += '&savingsFromDate=' + encodeURIComponent($('#savingsFromDateInput').val());
                }
                if ($('#savingsToDateInput').val()) {
                    url += '&savingsToDate=' + encodeURIComponent($('#savingsToDateInput').val());
                }
            }
            
            if (currentSavingsFilter === 'amount') {
                if ($('#savingsMinAmountInput').val()) {
                    url += '&savingsMinAmount=' + encodeURIComponent($('#savingsMinAmountInput').val());
                }
                if ($('#savingsMaxAmountInput').val()) {
                    url += '&savingsMaxAmount=' + encodeURIComponent($('#savingsMaxAmountInput').val());
                }
            }
            
            // Thêm các tham số lọc ngân hàng nếu có
            if ('@ViewBag.BankType' !== '') url += '&bankType=@ViewBag.BankType';
            if ('@ViewBag.BankFromDate' !== '') url += '&bankFromDate=@ViewBag.BankFromDate';
            if ('@ViewBag.BankToDate' !== '') url += '&bankToDate=@ViewBag.BankToDate';
            if ('@ViewBag.BankMinAmount' !== '') url += '&bankMinAmount=@ViewBag.BankMinAmount';
            if ('@ViewBag.BankMaxAmount' !== '') url += '&bankMaxAmount=@ViewBag.BankMaxAmount';
            
            window.location.href = url;
        });
        
        $('#clearSavingsFilter').on('click', function() {
            $('#savingsFilterInputContainer').empty();
            currentSavingsFilter = '';
            
            // Xóa bộ lọc tiết kiệm và giữ lại bộ lọc ngân hàng
            let url = window.location.pathname + '?id=@(ViewBag.Customer?.Id)';
            if ('@ViewBag.BankType' !== '') url += '&bankType=@ViewBag.BankType';
            if ('@ViewBag.BankFromDate' !== '') url += '&bankFromDate=@ViewBag.BankFromDate';
            if ('@ViewBag.BankToDate' !== '') url += '&bankToDate=@ViewBag.BankToDate';
            if ('@ViewBag.BankMinAmount' !== '') url += '&bankMinAmount=@ViewBag.BankMinAmount';
            if ('@ViewBag.BankMaxAmount' !== '') url += '&bankMaxAmount=@ViewBag.BankMaxAmount';
            
            window.location.href = url;
        });
        
        // Bộ lọc giao dịch ngân hàng
        let currentBankFilter = '';
        
        $('.bank-filter-option').on('click', function(e) {
            e.preventDefault();
            const filterType = $(this).data('filter');
            currentBankFilter = filterType;
            
            $('#bankFilterInputContainer').empty();
            
            switch(filterType) {
                case 'type':
                    $('#bankFilterInputContainer').append(`
                        <select id="bankTypeInput" class="form-select form-select-sm">
                            <option value="">Tất cả loại</option>
                            <option value="Nạp tiền" @(ViewBag.BankType == "Nạp tiền" ? "selected" : "")>Nạp tiền</option>
                            <option value="Rút tiền" @(ViewBag.BankType == "Rút tiền" ? "selected" : "")>Rút tiền</option>
                        </select>
                    `);
                    break;
                case 'date':
                    $('#bankFilterInputContainer').append(`
                        <input type="date" id="bankFromDateInput" class="form-control form-control-sm" placeholder="Từ ngày" value="@ViewBag.BankFromDate">
                        <input type="date" id="bankToDateInput" class="form-control form-control-sm" placeholder="Đến ngày" value="@ViewBag.BankToDate">
                    `);
                    break;
                case 'amount':
                    $('#bankFilterInputContainer').append(`
                        <input type="number" id="bankMinAmountInput" class="form-control form-control-sm" placeholder="Số tiền tối thiểu" value="@ViewBag.BankMinAmount">
                        <input type="number" id="bankMaxAmountInput" class="form-control form-control-sm" placeholder="Số tiền tối đa" value="@ViewBag.BankMaxAmount">
                    `);
                    break;
            }
        });
        
        $('#applyBankFilter').on('click', function() {
            // Tạo URL với các tham số lọc
            let url = window.location.pathname + '?id=@(ViewBag.Customer?.Id)';
            
            // Thêm các tham số lọc tiết kiệm nếu có
            if ('@ViewBag.SavingsType' !== '') url += '&savingsType=@ViewBag.SavingsType';
            if ('@ViewBag.SavingsFromDate' !== '') url += '&savingsFromDate=@ViewBag.SavingsFromDate';
            if ('@ViewBag.SavingsToDate' !== '') url += '&savingsToDate=@ViewBag.SavingsToDate';
            if ('@ViewBag.SavingsMinAmount' !== '') url += '&savingsMinAmount=@ViewBag.SavingsMinAmount';
            if ('@ViewBag.SavingsMaxAmount' !== '') url += '&savingsMaxAmount=@ViewBag.SavingsMaxAmount';
            
            if (currentBankFilter === 'type' && $('#bankTypeInput').val()) {
                url += '&bankType=' + encodeURIComponent($('#bankTypeInput').val());
            }
            
            if (currentBankFilter === 'date') {
                if ($('#bankFromDateInput').val()) {
                    url += '&bankFromDate=' + encodeURIComponent($('#bankFromDateInput').val());
                }
                if ($('#bankToDateInput').val()) {
                    url += '&bankToDate=' + encodeURIComponent($('#bankToDateInput').val());
                }
            }
            
            if (currentBankFilter === 'amount') {
                if ($('#bankMinAmountInput').val()) {
                    url += '&bankMinAmount=' + encodeURIComponent($('#bankMinAmountInput').val());
                }
                if ($('#bankMaxAmountInput').val()) {
                    url += '&bankMaxAmount=' + encodeURIComponent($('#bankMaxAmountInput').val());
                }
            }
            
            window.location.href = url;
        });
        
        $('#clearBankFilter').on('click', function() {
            $('#bankFilterInputContainer').empty();
            currentBankFilter = '';
            
            // Xóa bộ lọc ngân hàng và giữ lại bộ lọc tiết kiệm
            let url = window.location.pathname + '?id=@(ViewBag.Customer?.Id)';
            if ('@ViewBag.SavingsType' !== '') url += '&savingsType=@ViewBag.SavingsType';
            if ('@ViewBag.SavingsFromDate' !== '') url += '&savingsFromDate=@ViewBag.SavingsFromDate';
            if ('@ViewBag.SavingsToDate' !== '') url += '&savingsToDate=@ViewBag.SavingsToDate';
            if ('@ViewBag.SavingsMinAmount' !== '') url += '&savingsMinAmount=@ViewBag.SavingsMinAmount';
            if ('@ViewBag.SavingsMaxAmount' !== '') url += '&savingsMaxAmount=@ViewBag.SavingsMaxAmount';
            
            window.location.href = url;
        });
        
        // Khởi tạo bộ lọc nếu có giá trị
        @if (!string.IsNullOrEmpty(ViewBag.SavingsType?.ToString()) || 
             !string.IsNullOrEmpty(ViewBag.SavingsFromDate?.ToString()) || 
             !string.IsNullOrEmpty(ViewBag.SavingsToDate?.ToString()) || 
             ViewBag.SavingsMinAmount != null || 
             ViewBag.SavingsMaxAmount != null)
        {
            <text>
            // Tự động mở dropdown và chọn bộ lọc tiết kiệm phù hợp
            $(document).ready(function() {
                let filterType = '';
                @if (!string.IsNullOrEmpty(ViewBag.SavingsType?.ToString()))
                {
                    <text>
                    filterType = 'type';
                    </text>
                }
                else if (!string.IsNullOrEmpty(ViewBag.SavingsFromDate?.ToString()) || !string.IsNullOrEmpty(ViewBag.SavingsToDate?.ToString()))
                {
                    <text>
                    filterType = 'date';
                    </text>
                }
                else if (ViewBag.SavingsMinAmount != null || ViewBag.SavingsMaxAmount != null)
                {
                    <text>
                    filterType = 'amount';
                    </text>
                }
                
                if (filterType) {
                    $('.savings-filter-option[data-filter="' + filterType + '"]').trigger('click');
                }
            });
            </text>
        }
        
        @if (!string.IsNullOrEmpty(ViewBag.BankType?.ToString()) || 
             !string.IsNullOrEmpty(ViewBag.BankFromDate?.ToString()) || 
             !string.IsNullOrEmpty(ViewBag.BankToDate?.ToString()) || 
             ViewBag.BankMinAmount != null || 
             ViewBag.BankMaxAmount != null)
        {
            <text>
            // Tự động mở dropdown và chọn bộ lọc ngân hàng phù hợp
            $(document).ready(function() {
                let filterType = '';
                @if (!string.IsNullOrEmpty(ViewBag.BankType?.ToString()))
                {
                    <text>
                    filterType = 'type';
                    </text>
                }
                else if (!string.IsNullOrEmpty(ViewBag.BankFromDate?.ToString()) || !string.IsNullOrEmpty(ViewBag.BankToDate?.ToString()))
                {
                    <text>
                    filterType = 'date';
                    </text>
                }
                else if (ViewBag.BankMinAmount != null || ViewBag.BankMaxAmount != null)
                {
                    <text>
                    filterType = 'amount';
                    </text>
                }
                
                if (filterType) {
                    $('.bank-filter-option[data-filter="' + filterType + '"]').trigger('click');
                }
            });
            </text>
        }
    });
</script>
}
