@{
    ViewData["Title"] = "Từ chối giao dịch";
    Layout = "_LayoutManagement";
    
    var transaction = ViewBag.Transaction as GiaoDichTietKiem;
}

<div class="dashboard-container">
    <aside class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Chức năng</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Management")"><i class="fas fa-chart-line me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("TransactionApproval","Management")"><i class="fas fa-check-circle me-2"></i>Duyệt giao dịch</a></li>
            <li class="category-item"><a href="@Url.Action("SavingsBookManagement","Management")"><i class="fas fa-book me-2"></i>Quản lý sổ tiết kiệm</a></li>
            <li class="category-item"><a href="@Url.Action("TermDepositProducts","Management")"><i class="fas fa-box me-2"></i>Gói tiết kiệm</a></li>
            <li class="category-item"><a href="@Url.Action("TellerManagement","Management")"><i class="fas fa-users-cog me-2"></i>Quản lý nhân viên</a></li>
            <li class="category-item"><a href="@Url.Action("CustomerManagement","Management")" class="active"><i class="fas fa-users me-2"></i>Quản lý khách hàng</a></li>
            <li class="category-item"><a href="@Url.Action("DailyReports","Management")"><i class="fas fa-file-alt me-2"></i>Báo cáo nhân viên</a></li>
            <li class="category-item"><a href="@Url.Action("ManageAppointments","Management")"><i class="fas fa-calendar-alt me-2"></i>Quản lý lịch hẹn</a></li>
        </ul>
    </aside>

    <section class="content">
        <div class="mb-4">
            <h2 class="section-title mb-2"><i class="fas fa-times-circle me-2"></i>Từ chối giao dịch</h2>
            <p class="text-muted">Nhập lý do từ chối giao dịch #@transaction?.MaGD</p>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="fas fa-info-circle me-2"></i>Thông tin giao dịch
            </div>
            <div class="card-body">
                @if (transaction != null)
                {
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th>Mã giao dịch:</th>
                                    <td>@transaction.MaGD</td>
                                </tr>
                                <tr>
                                    <th>Loại giao dịch:</th>
                                    <td>@transaction.LoaiGD</td>
                                </tr>
                                <tr>
                                    <th>Số tiền:</th>
                                    <td>@string.Format("{0:N0}", transaction.SoTien) đ</td>
                                </tr>
                                <tr>
                                    <th>Ngày giao dịch:</th>
                                    <td>@transaction.NgayGD.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            @if (transaction.SoTietKiem != null)
                            {
                                <table class="table table-borderless">
                                    <tr>
                                        <th>Mã sổ tiết kiệm:</th>
                                        <td>#@transaction.SoTietKiem.MaSTK</td>
                                    </tr>
                                    <tr>
                                        <th>Số tài khoản:</th>
                                        <td>@transaction.SoTietKiem.SoTaiKhoan</td>
                                    </tr>
                                    <tr>
                                        <th>Khách hàng:</th>
                                        <td>@transaction.SoTietKiem.TaiKhoanNganHang?.KhachHang?.HoTen</td>
                                    </tr>
                                    <tr>
                                        <th>Trạng thái:</th>
                                        <td>@transaction.SoTietKiem.TrangThai</td>
                                    </tr>
                                </table>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header">
                <i class="fas fa-comment-dots me-2"></i>Nhập lý do từ chối
            </div>
            <div class="card-body">
                <form method="post" asp-action="RejectTransaction" asp-controller="Management">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="maGD" value="@transaction?.MaGD" />
                    
                    <div class="mb-3">
                        <label class="form-label">Lý do từ chối <span class="text-danger">*</span></label>
                        <textarea class="form-control" name="reason" rows="4" placeholder="Nhập lý do từ chối giao dịch này..." required></textarea>
                        <div class="form-text">Lý do từ chối sẽ được gửi đến khách hàng qua hệ thống thông báo.</div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Xác nhận từ chối giao dịch này?')">
                            <i class="fas fa-times-circle me-2"></i>Xác nhận từ chối
                        </button>
                        <a href="@Url.Action("TransactionApproval", "Management")" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </section>
</div>