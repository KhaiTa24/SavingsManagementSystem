@model HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.BaoCaoGiaoDichNgay
@{
    ViewData["Title"] = "Chi tiết báo cáo";
    Layout = "_LayoutManagement";
}

<div class="dashboard-container">
    <aside class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Chức năng</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Management")"><i class="fas fa-chart-line me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("TransactionApproval","Management")"><i class="fas fa-check-circle me-2"></i>Duyệt giao dịch</a></li>
            <li class="category-item"><a href="@Url.Action("SavingsBookManagement","Management")"><i class="fas fa-book me-2"></i>Quản lý sổ tiết kiệm</a></li>
            <li class="category-item"><a href="@Url.Action("TermDepositProducts","Management")"><i class="fas fa-box me-2"></i>Gói tiết kiệm</a></li>
            <li class="category-item"><a href="@Url.Action("TellerManagement","Management")"><i class="fas fa-users-cog me-2"></i>Quản lý nhân viên</a></li>
            <li class="category-item"><a href="@Url.Action("CustomerManagement","Management")" class="active"><i class="fas fa-users me-2"></i>Quản lý khách hàng</a></li>
            <li class="category-item"><a href="@Url.Action("DailyReports","Management")"><i class="fas fa-file-alt me-2"></i>Báo cáo nhân viên</a></li>
            <li class="category-item"><a href="@Url.Action("ManageAppointments","Management")"><i class="fas fa-calendar-alt me-2"></i>Quản lý lịch hẹn</a></li>
        </ul>
    </aside>

    <section class="content">
        @if (TempData["ActionMessage"] != null)
        {
            <div class="alert alert-success mb-3" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["ActionMessage"]
            </div>
        }

        <div class="mb-4">
            <h2 class="section-title mb-2"><i class="fas fa-file-alt me-2"></i>Chi tiết báo cáo #@Model.MaBaoCao</h2>
            <p class="text-muted">Thông tin chi tiết về báo cáo giao dịch ngày.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Thông tin chung</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Mã báo cáo:</strong> #@Model.MaBaoCao</p>
                                <p><strong>Ngày báo cáo:</strong> @Model.NgayBaoCao.ToString("dd/MM/yyyy")</p>
                                <p><strong>Loại báo cáo:</strong> 
                                    @if (Model.LoaiBaoCao == "BaoCaoSoTien")
                                    {
                                        <span class="badge bg-primary">Báo cáo số tiền thu chi</span>
                                    }
                                    else if (Model.LoaiBaoCao == "BaoCaoSoLuongGD")
                                    {
                                        <span class="badge bg-success">Báo cáo số lượng giao dịch</span>
                                    }
                                </p>
                                <p><strong>Ngày tạo:</strong> @Model.NgayLap.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Nhân viên lập:</strong> @(Model.NhanVien?.HoTenNV ?? Model.NhanVien?.HoTen ?? "Không xác định")</p>
                                <p><strong>Mã nhân viên:</strong> @Model.MaNV</p>
                            </div>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(Model.GhiChu))
                        {
                            <div class="mt-3">
                                <p><strong>Ghi chú:</strong></p>
                                <div class="alert alert-info">
                                    @Model.GhiChu
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (Model.LoaiBaoCao == "BaoCaoSoTien")
                {
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-money-bill-wave me-2"></i>Báo cáo tài chính</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-number text-success">+@string.Format("{0:N0}", Model.TongSoTienThu) đ</div>
                                        <div class="stat-label">Tổng tiền thu</div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-number text-danger">-@string.Format("{0:N0}", Model.TongSoTienChi) đ</div>
                                        <div class="stat-label">Tổng tiền chi</div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="stat-card text-center p-3 @(Model.TongTienRong >= 0 ? "text-success" : "text-danger")">
                                        <div class="stat-number">@string.Format("{0:N0}", Model.TongTienRong) đ</div>
                                        <div class="stat-label">Tổng tiền ròng</div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mt-3">
                                <p><strong>Tổng số giao dịch:</strong> @Model.TongSoGiaoDich</p>
                            </div>
                        </div>
                    </div>
                }
                else if (Model.LoaiBaoCao == "BaoCaoSoLuongGD")
                {
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-list me-2"></i>Chi tiết số lượng giao dịch</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-number text-primary">@Model.SoGiaoDichGui</div>
                                        <div class="stat-label">Gửi tiền</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-number text-warning">@Model.SoGiaoDichRut</div>
                                        <div class="stat-label">Rút tiền</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-number text-info">@Model.SoGiaoDichMoSo</div>
                                        <div class="stat-label">Mở sổ</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-number text-secondary">@Model.SoGiaoDichTatToan</div>
                                        <div class="stat-label">Tất toán</div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mt-3">
                                <p><strong>Tổng số giao dịch:</strong> @Model.TongSoGiaoDich</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-money-bill-wave me-2"></i>Thông tin tài chính</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4">
                                    <p><strong>Tổng tiền thu:</strong> <span class="text-success">+@string.Format("{0:N0}", Model.TongSoTienThu) đ</span></p>
                                </div>
                                <div class="col-md-4">
                                    <p><strong>Tổng tiền chi:</strong> <span class="text-danger">-@string.Format("{0:N0}", Model.TongSoTienChi) đ</span></p>
                                </div>
                                <div class="col-md-4">
                                    <p><strong>Tổng tiền ròng:</strong> 
                                        <span class="@(Model.TongTienRong >= 0 ? "text-success" : "text-danger")">
                                            @string.Format("{0:N0}", Model.TongTienRong) đ
                                        </span>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Bảng chi tiết giao dịch tiết kiệm -->
                <div class="card mt-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-book me-2"></i>Chi tiết giao dịch tiết kiệm</h5>
                    </div>
                    <div class="card-body">
                        @{
                            var savingsTransactions = ((List<dynamic>)ViewBag.TransactionDetails)?
                                .Where(t => t.LoaiGD == "Gửi" || t.LoaiGD == "Rút")
                                .ToList() ?? new List<dynamic>();
                        }
                        
                        @if (savingsTransactions.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Mã GD</th>
                                            <th>Loại GD</th>
                                            <th>Số tiền</th>
                                            <th>Tài khoản KH</th>
                                            <th>Họ tên KH</th>
                                            <th>Thời gian</th>
                                            <th>Trạng thái</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var transaction in savingsTransactions)
                                        {
                                            <tr>
                                                <td>@transaction.MaGD</td>
                                                <td>
                                                    @if (transaction.LoaiGD == "Gửi")
                                                    {
                                                        <span class="badge bg-success">@transaction.LoaiGD</span>
                                                    }
                                                    else if (transaction.LoaiGD == "Rút")
                                                    {
                                                        <span class="badge bg-danger">@transaction.LoaiGD</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">@transaction.LoaiGD</span>
                                                    }
                                                </td>
                                                <td>@string.Format("{0:N0}", transaction.SoTien) đ</td>
                                                <td>@(transaction.SoTaiKhoan ?? "N/A")</td>
                                                <td>@(transaction.HoTenKH ?? "N/A")</td>
                                                <td>@transaction.ThoiGian.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>
                                                    @if (transaction.TrangThai == "Thành công")
                                                    {
                                                        <span class="badge bg-success">@transaction.TrangThai</span>
                                                    }
                                                    else if (transaction.TrangThai == "Thất bại")
                                                    {
                                                        <span class="badge bg-danger">@transaction.TrangThai</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">@transaction.TrangThai</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i> Không có giao dịch tiết kiệm nào trong ngày này.
                            </div>
                        }
                    </div>
                </div>

                <!-- Bảng chi tiết giao dịch ngân hàng -->
                <div class="card mt-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-money-bill-wave me-2"></i>Chi tiết giao dịch ngân hàng</h5>
                    </div>
                    <div class="card-body">
                        @{
                            var bankTransactions = ((List<dynamic>)ViewBag.TransactionDetails)?
                                .Where(t => t.LoaiGD == "Nạp tiền" || t.LoaiGD == "Rút tiền")
                                .ToList() ?? new List<dynamic>();
                        }
                        
                        @if (bankTransactions.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Mã GD</th>
                                            <th>Loại GD</th>
                                            <th>Số tiền</th>
                                            <th>Tài khoản KH</th>
                                            <th>Họ tên KH</th>
                                            <th>Thời gian</th>
                                            <th>Trạng thái</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var transaction in bankTransactions)
                                        {
                                            <tr>
                                                <td>@transaction.MaGD</td>
                                                <td>
                                                    @if (transaction.LoaiGD == "Nạp tiền")
                                                    {
                                                        <span class="badge bg-primary">@transaction.LoaiGD</span>
                                                    }
                                                    else if (transaction.LoaiGD == "Rút tiền")
                                                    {
                                                        <span class="badge bg-warning">@transaction.LoaiGD</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">@transaction.LoaiGD</span>
                                                    }
                                                </td>
                                                <td>@string.Format("{0:N0}", transaction.SoTien) đ</td>
                                                <td>@(transaction.SoTaiKhoan ?? "N/A")</td>
                                                <td>@(transaction.HoTenKH ?? "N/A")</td>
                                                <td>@transaction.ThoiGian.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>
                                                    @if (transaction.TrangThai == "Thành công")
                                                    {
                                                        <span class="badge bg-success">@transaction.TrangThai</span>
                                                    }
                                                    else if (transaction.TrangThai == "Thất bại")
                                                    {
                                                        <span class="badge bg-danger">@transaction.TrangThai</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">@transaction.TrangThai</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i> Không có giao dịch ngân hàng nào trong ngày này.
                            </div>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-history me-2"></i>Thao tác</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a href="@Url.Action("DailyReports", "Management")" class="btn btn-primary">
                                <i class="fas fa-arrow-left me-2"></i> Quay lại danh sách
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>