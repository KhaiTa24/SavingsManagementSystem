@{
    ViewData["Title"] = "Quản lý khách hàng";
    Layout = "_LayoutTransaction";
}

<div class="dashboard-container">
    <<aside class="sidebar">
        <h3><i class="fas fa-bars me-2"></i>Chức năng</h3>
        <ul class="category-list">
            <li class="category-item"><a href="@Url.Action("Overview","Transaction")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Overview" ? "active" : "")"><i class="fas fa-chart-line me-2"></i>Tổng quan</a></li>
            <li class="category-item"><a href="@Url.Action("Customers","Transaction")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Customers" ? "active" : "")"><i class="fas fa-users me-2"></i>Quản lý khách hàng</a></li>
            <li class="category-item"><a href="@Url.Action("Deposit","BankingTransaction")"><i class="fas fa-money-bill-wave me-2"></i>Nạp tiền</a></li>
            <li class="category-item"><a href="@Url.Action("Withdraw","BankingTransaction")"><i class="fas fa-money-bill-wave me-2"></i>Rút tiền</a></li>
            <li class="category-item"><a href="@Url.Action("OpenSavingsBook","Transaction")"><i class="fas fa-book me-2"></i>Mở sổ tiết kiệm</a></li>
            <li class="category-item"><a href="@Url.Action("Create","DailyReport")"><i class="fas fa-file-alt me-2"></i>Tạo báo cáo</a></li>
            <li class="category-item"><a href="@Url.Action("CreateNotificationPage","Transaction")"><i class="fas fa-bell me-2"></i>Tạo thông báo</a></li>
            <li class="category-item"><a href="@Url.Action("IncidentReportPage","Transaction")"><i class="fas fa-exclamation-triangle me-2"></i>Báo cáo sự cố</a></li>
        </ul>
    </aside>

    <section class="content">
        <div class="mb-4">
            <h2 class="section-title mb-2"><i class="fas fa-users me-2"></i>Quản lý khách hàng</h2>
            <p class="text-muted">Tìm kiếm và quản lý thông tin khách hàng.</p>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-8">
                        <input type="text" class="form-control" name="q" value="@ViewBag.Query" placeholder="Tìm kiếm theo tên, email, CCCD hoặc SĐT...">
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-search me-2"></i>Tìm kiếm</button>
                    </div>
                </form>
            </div>
        </div>

        @if (ViewBag.Users != null)
        {
            var users = ViewBag.Users as List<HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.User>;
            if (users.Any())
            {
                <div class="card">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Họ tên</th>
                                        <th>CCCD</th>
                                        <th>Email</th>
                                        <th>SĐT</th>
                                        <th>Địa chỉ</th>
                                        <th>Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var customer in users)
                                    {
                                        <tr>
                                            <td>@customer.HoTen</td>
                                            <td>@customer.CCCD</td>
                                            <td>@customer.Email</td>
                                            <td>@customer.SDT</td>
                                            <td>@customer.DiaChi</td>
                                            <td>
                                                <a href="@Url.Action("CustomerDetails", "Transaction", new { id = customer.Id })" class="btn btn-info btn-sm"><i class="fas fa-eye"></i> Xem</a>
                                                <a href="@Url.Action("UpdateCustomerContactPage", "Transaction", new { id = customer.Id })" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i> Sửa</a>
                                                <form asp-action="VerifyCustomer" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@customer.Id" />
                                                    <button type="submit" class="btn btn-secondary btn-sm" onclick="return confirm('Bạn có chắc chắn muốn yêu cầu xác minh danh tính khách hàng này?')"><i class="fas fa-user-check"></i> Xác minh</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i> Không tìm thấy khách hàng nào.
                </div>
            }
        }
    </section>
</div>