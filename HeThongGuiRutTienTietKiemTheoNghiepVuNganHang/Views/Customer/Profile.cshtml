@{
    ViewData["Title"] = "Hồ sơ người dùng";
    Layout = "~/Views/Shared/_LayoutCustomer.cshtml";
}

<!-- Hero -->
<section class="hero" style="background: linear-gradient(135deg, #2a5298 0%, #74a7db 100%); color: #fff; padding: 1.5rem 0; margin-bottom: 2rem;">
    <div class="container">
        <div class="text-center">
            <h2 style="font-weight: 800; margin-bottom: 0.25rem; font-size: 1.8rem;"><i class="fas fa-user-circle me-2"></i>Hồ sơ người dùng</h2>
            <p style="opacity: 0.95; margin-bottom: 0;">Quản lý thông tin tài khoản và sổ tiết kiệm của bạn</p>
        </div>
    </div>
</section>

<div class="container my-4" style="max-width: 1200px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Thông tin cơ bản -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-user me-2"></i>Thông tin cơ bản</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Họ tên:</strong> @ViewBag.User.HoTen</p>
                    <p><strong>Email:</strong> @ViewBag.User.Email</p>
                    <p><strong>Số điện thoại:</strong> @ViewBag.User.SDT</p>
                </div>
                <div class="col-md-6">
                    <p><strong>CCCD:</strong> @ViewBag.User.CCCD</p>
                    <p><strong>Địa chỉ:</strong> @ViewBag.User.DiaChi</p>
                    <p><strong>Hạng khách hàng:</strong> <span class="badge bg-primary">@ViewBag.CustomerRank</span></p>
                </div>
            </div>
            <a href="@Url.Action("ChangePassword", "Customer")" class="btn btn-primary">
                <i class="fas fa-key me-2"></i>Đổi mật khẩu
            </a>
            <a href="@Url.Action("ChangePin", "Customer")" class="btn btn-secondary ms-2">
                <i class="fas fa-lock me-2"></i>Đổi mã PIN Digital OTP
            </a>
        </div>
    </div>

    <!-- Thông tin tài khoản ngân hàng và sổ tiết kiệm -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-university me-2"></i>Tài khoản ngân hàng và sổ tiết kiệm</h5>
        </div>
        <div class="card-body">
            <p><strong>Tổng số tiền tiết kiệm:</strong> <span class="text-success">@string.Format("{0:N0}", ViewBag.TotalSavings) đ</span></p>
            
            @{
                var bankAccounts = ViewBag.BankAccounts as List<HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.TaiKhoanNganHang>;
            }
            
            @if (bankAccounts != null && bankAccounts.Count > 0)
            {
                foreach (var account in bankAccounts)
                {
                    <div class="card mb-3">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="fas fa-credit-card me-2"></i>Tài khoản: @account.SoTaiKhoan</h6>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <p><strong>Số dư:</strong> <span class="badge bg-primary">@string.Format("{0:N0}", account.SoDu) đ</span></p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong>Trạng thái:</strong> <span class="badge bg-success">@account.TrangThai</span></p>
                                </div>
                            </div>
                            
                            @{
                                var savingsBooks = account.SoTietKiems as ICollection<HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.SoTietKiem>;
                            }
                            
                            @if (savingsBooks != null && savingsBooks.Count > 0)
                            {
                                <h6><i class="fas fa-book me-2"></i>Sổ tiết kiệm:</h6>
                                <div class="table-responsive">
                                    <table class="table table-striped">
                                        <thead>
                                            <tr>
                                                <th>Mã sổ</th>
                                                <th>Số tiền</th>
                                                <th>Kỳ hạn</th>
                                                <th>Lãi suất</th>
                                                <th>Ngày mở</th>
                                                <th>Trạng thái</th>
                                                <th>Hành động</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var savingsBook in savingsBooks)
                                            {
                                                <tr>
                                                    <td>#@savingsBook.MaSTK</td>
                                                    <td>@string.Format("{0:N0}", savingsBook.SoTienGui) đ</td>
                                                    <td>@savingsBook.KyHan tháng</td>
                                                    <td>@savingsBook.LaiSuat%</td>
                                                    <td>@savingsBook.NgayMoSo.ToString("dd/MM/yyyy")</td>
                                                    <td>
                                                        @if (savingsBook.TrangThai == "Đang hoạt động")
                                                        {
                                                            <span class="badge bg-info">@savingsBook.TrangThai</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary">@savingsBook.TrangThai</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <a href="@Url.Action("SavingsBookDetails", "Customer", new { id = savingsBook.MaSTK })" class="btn btn-sm btn-info">
                                                            <i class="fas fa-eye me-1"></i>Xem
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle me-2"></i>Chưa có sổ tiết kiệm nào.
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>Bạn chưa có tài khoản ngân hàng nào.
                </div>
            }
        </div>
    </div>

    <!-- Danh sách lịch hẹn -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-calendar-check me-2"></i>Lịch hẹn của bạn</h5>
        </div>
        <div class="card-body">
            @{
                var appointments = ViewBag.Appointments as List<HeThongGuiRutTienTietKiemTheoNghiepVuNganHang.Models.LichHen>;
            }
            
            @if (appointments != null && appointments.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Mã lịch hẹn</th>
                                <th>Dịch vụ</th>
                                <th>Chi nhánh</th>
                                <th>Ngày giao dịch</th>
                                <th>Khung giờ</th>
                                <th>Trạng thái</th>
                                <th>Thời gian tạo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appointment in appointments)
                            {
                                <tr>
                                    <td>@appointment.MaLichHen</td>
                                    <td>@appointment.LoaiDichVu?.TenDV</td>
                                    <td>@appointment.ChiNhanh?.TenChiNhanh</td>
                                    <td>@appointment.NgayGiaoDich.ToString("dd/MM/yyyy")</td>
                                    <td>@appointment.KhungGio</td>
                                    <td>
                                        @if (appointment.TrangThai == "ChoDuyet")
                                        {
                                            <span class="badge bg-warning">Chờ duyệt</span>
                                        }
                                        else if (appointment.TrangThai == "DaDuyet")
                                        {
                                            <span class="badge bg-success">Đã duyệt</span>
                                        }
                                        else if (appointment.TrangThai == "DaHuy")
                                        {
                                            <span class="badge bg-danger">Đã hủy</span>
                                        }
                                    </td>
                                    <td>@appointment.ThoiGianTao.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>Bạn chưa có lịch hẹn nào. 
                    <a href="@Url.Action("BookAppointment", "Customer")" class="alert-link">Đặt lịch hẹn ngay</a>.
                </div>
            }
        </div>
    </div>
</div>