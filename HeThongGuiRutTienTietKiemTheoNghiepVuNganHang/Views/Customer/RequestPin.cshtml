@{
    ViewData["Title"] = "Xác thực Mã PIN Digital OTP";
    Layout = "~/Views/Shared/_LayoutCustomer.cshtml";
    var purpose = ViewBag.Purpose as string;
    var purposeText = ViewBag.PurposeText as string;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="mb-0"><i class="fas fa-lock me-2"></i>Xác thực Mã PIN Digital OTP</h3>
                </div>
                <div class="card-body">
                    <p>Vui lòng nhập Mã PIN Digital OTP của bạn để tiếp tục @purposeText.</p>
                    
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }
                    
                    <form asp-action="RequestPin" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="purpose" value="@purpose" />
                        
                        <div class="mb-3">
                            <label class="form-label">Mã PIN Digital OTP</label>
                            <input type="password" class="form-control" name="pin" placeholder="Nhập mã PIN 6 chữ số" required maxlength="6" />
                            <div class="form-text">Vui lòng nhập mã PIN đã thiết lập của bạn.</div>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-check me-2"></i>Xác thực
                            </button>
                            
                            <a href="@Url.Action("Dashboard", "Customer")" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>