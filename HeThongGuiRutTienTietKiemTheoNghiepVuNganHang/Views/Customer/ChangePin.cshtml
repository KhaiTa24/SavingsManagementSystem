@{
    ViewData["Title"] = "Đổi mã PIN Digital OTP";
    Layout = "~/Views/Shared/_LayoutCustomer.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="mb-0"><i class="fas fa-lock me-2"></i>Đổi mã PIN Digital OTP</h3>
                </div>
                <div class="card-body">
                    <p class="text-muted">Hệ thống sẽ gửi một mã OTP đến email của bạn để xác minh danh tính trước khi cho phép đổi mã PIN.</p>
                    
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }
                    
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }
                    
                    <form asp-action="ChangePin" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-2"></i>Gửi mã OTP đến email
                            </button>
                            
                            <a href="@Url.Action("Profile", "Customer")" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Quay lại hồ sơ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>